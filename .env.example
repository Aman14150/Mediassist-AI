# Copy this file to .env. Never commit the real .env file.
APP_ENV=development
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Kolkata

# Use a long random value (at least 32 characters). ElevenLabs sends this as
# Recommended ElevenLabs tool header: X-MediAssist-Key: <value>.
# Authorization: Bearer <value> is also supported.
ELEVENLABS_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Generate with: php -r "echo password_hash('your password', PASSWORD_DEFAULT), PHP_EOL;"
STAFF_PASSWORD_HASH=replace-with-a-password-hash

# Use sqlite for local/XAMPP/Docker development and sqlsrv on Azure.
DB_CONNECTION=sqlite
DATABASE_PATH=storage/medicare.sqlite

# Required only when DB_CONNECTION=sqlsrv. Store these as Azure App Service
# application settings; do not commit real credentials to this file.
AZURE_SQL_HOST=
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=
AZURE_SQL_USERNAME=
AZURE_SQL_PASSWORD=

# Comma-separated origins allowed to use the browser booking APIs.
ALLOWED_ORIGINS=http://localhost:8080

# Used to sign short-lived slot tokens returned by availability checks.
SLOT_TOKEN_SECRET=replace-with-a-second-long-random-secret
